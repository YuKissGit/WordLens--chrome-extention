{
    "manifest_version": 3,
    "name": "WordLens Extension",
    "version": "1.0",
    "description": "Select English words on any webpage to see dictionary definitions and images.",
    "permissions": [
        "storage",
        "activeTab",
        "offscreen"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "WordLens Settings"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "content.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}