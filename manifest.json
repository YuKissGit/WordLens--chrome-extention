{
  "manifest_version": 3,
  "name": "Quick Look: Images & Dictionary",
  "version": "1.0",
  "description": "Select text to see Google Images, Dictionary definitions, and custom links.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Extension Settings"
  }
}
